{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "do-ui/brief.schema.json",
  "title": "DO-UI Brief",
  "description": "Validated output of the /makeui question round. Drives the rest of the pipeline.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "brand",
    "tone",
    "audience",
    "headline",
    "subheadline",
    "features",
    "cta",
    "footer",
    "palette",
    "fonts",
    "visual",
    "stack",
    "deployTarget"
  ],
  "properties": {
    "brand": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "tone": {
      "type": "string",
      "enum": ["cinematic", "bold", "minimal", "playful", "technical", "editorial"]
    },
    "audience": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "headline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 140
    },
    "subheadline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "features": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "body"],
        "properties": {
          "title": { "type": "string", "minLength": 1, "maxLength": 60 },
          "body": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "cta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "href"],
      "properties": {
        "label": { "type": "string", "minLength": 1, "maxLength": 40 },
        "href": { "type": "string", "minLength": 1 }
      }
    },
    "footer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "palette": {
      "type": "array",
      "minItems": 2,
      "maxItems": 8,
      "items": {
        "type": "string",
        "pattern": "^#([0-9a-fA-F]{6}|[0-9a-fA-F]{8})$"
      }
    },
    "fonts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["family", "role"],
        "properties": {
          "family": { "type": "string", "minLength": 1, "maxLength": 80 },
          "role": { "type": "string", "enum": ["display", "body"] },
          "source": { "type": "string", "enum": ["google", "awwwards-free", "local"] },
          "weights": {
            "type": "array",
            "items": { "type": "integer", "minimum": 100, "maximum": 900 }
          }
        }
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "surface", "bwLayoutPass"],
      "properties": {
        "base": { "type": "string", "enum": ["light", "dark", "colored"] },
        "surface": { "type": "string", "enum": ["bordered", "borderless", "elevated"] },
        "bwLayoutPass": { "type": "boolean" }
      }
    },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "language", "styling"],
      "properties": {
        "framework": { "type": "string", "enum": ["next", "vite-react", "astro", "remix"] },
        "language": { "type": "string", "enum": ["ts", "js"] },
        "styling": { "type": "string", "enum": ["tailwind", "css-modules", "vanilla"] },
        "motion": {
          "type": "array",
          "items": { "type": "string", "enum": ["gsap", "react-spring", "framer-motion", "css-only"] },
          "default": ["gsap", "react-spring", "framer-motion"]
        }
      }
    },
    "deployTarget": {
      "type": "string",
      "enum": ["vercel", "netlify", "static-export", "hostinger"]
    },
    "references": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "screenshot": { "type": "string" },
        "screenshotBW": { "type": "string" },
        "site": { "type": "string" },
        "siteMode": { "type": "string", "enum": ["url-only", "screenshot"] },
        "siteShot": { "type": "string" },
        "animation": {
          "type": "array",
          "items": { "type": "string" }
        },
        "media": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
